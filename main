/*
  main.c - Glavni pokretac programa
  Ovdje zapocinje izvrsavanje. Program prvo ucitava podatke iz binarne datoteke 
  ako ona postoji, cime osiguravamo perzistentnost podataka.
*/

#include "header.h"

int main(void) {
    // Inicijalizacija pomocnih alata
    init_utils();

    const char* DATA_FILE = "data.bin";

    // Inicijalizacija struktura na prazno (velicina 0, pokazivaci NULL)
    ProductArray  products;
    SupplierArray suppliers;
    product_init(&products);
    supplier_init(&suppliers);

    // Provjera postoji li datoteka s podacima
    if (file_exists(DATA_FILE)) {
        printf("Pronasao sam datoteku '%s' s prethodnim podacima.\n", DATA_FILE);
        int choice = read_int("Zelis li ucitati postojece podatke? (1 = DA, 0 = NE): ");
        if (choice == 1) {
            // fileio_load_all vrsi dinamicku alokaciju memorije za podatke
            if (fileio_load_all(DATA_FILE, &products, &suppliers) != 0)
                fprintf(stderr, "Greska pri ucitavanju. Pokrece se prazno skladiste.\n");
            else if (globalConfig.verbose)
                printf("Podaci uspjesno ucitani iz %s\n", DATA_FILE);
        }
    }

    // Ulazak u glavni interaktivni izbornik
    main_menu(&products, &suppliers, DATA_FILE);

    // OSLOBADJANJE MEMORIJE (Ciscenje)
    // Vrlo vazno za prezentaciju: pokazujemo odgovorno upravljanje memorijom.
    product_free(&products);
    supplier_free(&suppliers);

    printf("Program zavrsen. Pozdrav!\n");
    return 0;
}
main_menu(&products, &suppliers, DATA_FILE);

    if (fileio_save_all(DATA_FILE, &products, &suppliers) == 0) {
        if (globalConfig.verbose) printf("Podaci spremljeni prije izlaza.\n");
    } else {
        fprintf(stderr, "Greska pri spremanju podataka.\n");
    }

    product_free(&products);
    supplier_free(&suppliers);
    cleanup_utils();
    return 0;
}
