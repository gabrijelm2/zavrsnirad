/*
  fileio.c
  Ucitavanje i spremanje podataka u binarnu datoteku, kopiranje datoteka
*/

#include "header.h"

int fileio_save_all(const char* filename, const ProductArray* products, const SupplierArray* suppliers) {
    if (!filename || !products || !suppliers) return -1;

    FILE* f = fopen(filename, "wb");
    if (!f) { perror("fopen za pisanje"); return errno; }

    if (fwrite(&products->size,  sizeof(size_t), 1, f) != 1) { perror("fwrite"); fclose(f); return -1; }
    if (fwrite(&suppliers->size, sizeof(size_t), 1, f) != 1) { perror("fwrite"); fclose(f); return -1; }

    if (products->size > 0) {
        if (fwrite(products->items, sizeof(Product), products->size, f) != products->size) {
            perror("fwrite products"); fclose(f); return -1;
        }
    }
    if (suppliers->size > 0) {
        if (fwrite(suppliers->items, sizeof(Supplier), suppliers->size, f) != suppliers->size) {
            perror("fwrite suppliers"); fclose(f); return -1;
        }
    }

    fclose(f);
    return 0;
}

int fileio_load_all(const char* filename, ProductArray* products, SupplierArray* suppliers) {
    if (!filename || !products || !suppliers) return -1;

    FILE* f = fopen(filename, "rb");
    if (!f) { perror("fopen za citanje"); return errno; }

    size_t pcount = 0, scount = 0;

    if (fread(&pcount, sizeof(size_t), 1, f) != 1) {
        if (feof(f)) { fclose(f); return 0; }
        perror("fread"); fclose(f); return -1;
    }
    if (fread(&scount, sizeof(size_t), 1, f) != 1) {
        perror("fread"); fclose(f); return -1;
    }

    product_init(products);
    supplier_init(suppliers);

    if (pcount > 0) {
        products->items = (Product*)malloc(pcount * sizeof(Product));
        if (!products->items) { fclose(f); return -1; }
        if (fread(products->items, sizeof(Product), pcount, f) != pcount) {
            perror("fread products"); free(products->items); fclose(f); return -1;
        }
        products->size     = pcount;
        products->capacity = pcount;
    }

    if (scount > 0) {
        suppliers->items = (Supplier*)malloc(scount * sizeof(Supplier));
        if (!suppliers->items) { fclose(f); return -1; }
        if (fread(suppliers->items, sizeof(Supplier), scount, f) != scount) {
            perror("fread suppliers"); free(suppliers->items); fclose(f); return -1;
        }
        suppliers->size     = scount;
        suppliers->capacity = scount;
    }

    fclose(f);
    product_remove_duplicates(products);
    supplier_remove_duplicates(suppliers);
    return 0;
}

int file_copy(const char* src, const char* dst) {
    if (!src || !dst) return -1;

    FILE* fs = fopen(src, "rb");
    if (!fs) { perror("fopen src"); return errno; }

    FILE* fd = fopen(dst, "wb");
    if (!fd) { perror("fopen dst"); fclose(fs); return errno; }

    char   buf[4096];
    size_t n;
    while ((n = fread(buf, 1, sizeof(buf), fs)) > 0) {
        if (fwrite(buf, 1, n, fd) != n) {
            perror("fwrite"); fclose(fs); fclose(fd); return -1;
        }
    }
    if (ferror(fs)) { perror("fread"); fclose(fs); fclose(fd); return -1; }

    fclose(fs);
    fclose(fd);
    return 0;
}
